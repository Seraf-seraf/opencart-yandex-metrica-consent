{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right"><button type="submit" form="form-metrica" class="btn btn-primary" title="{{ button_save }}"><i class="fa fa-save"></i></button><a href="{{ cancel }}" class="btn btn-default" title="{{ button_cancel }}"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}<div class="alert alert-danger">{{ error_warning }}</div>{% endif %}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-cog"></i> {{ text_edit }}</h3></div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" id="form-metrica" class="form-horizontal">
          <fieldset>
            <legend>{{ text_counter }}</legend>
            <div class="form-group required">
              <label class="col-sm-3 control-label" for="input-counter">{{ entry_counter }}</label>
              <div class="col-sm-9"><input name="analytics_yandex_metrica_counter" value="{{ analytics_yandex_metrica_counter }}" id="input-counter" class="form-control"><p class="help-block">{{ help_counter }}</p>{% if error_counter %}<div class="text-danger">{{ error_counter }}</div>{% endif %}</div>
            </div>
            {% for field, label in {'webvisor': entry_webvisor, 'ecommerce': entry_ecommerce, 'status': entry_status} %}
            <div class="form-group">
              <label class="col-sm-3 control-label" for="input-{{ field }}">{{ label }}</label>
              <div class="col-sm-9"><select name="analytics_yandex_metrica_{{ field }}" id="input-{{ field }}" class="form-control"><option value="1"{% if attribute(_context, 'analytics_yandex_metrica_' ~ field) %} selected{% endif %}>{{ text_enabled }}</option><option value="0"{% if not attribute(_context, 'analytics_yandex_metrica_' ~ field) %} selected{% endif %}>{{ text_disabled }}</option></select></div>
            </div>
            {% endfor %}
            <div class="alert alert-info">{{ help_goals }}</div>
          </fieldset>
          <fieldset>
            <legend>{{ text_cookie_banner }}</legend>
            <div class="form-group required">
              <label class="col-sm-3 control-label" for="input-cookie-days">{{ entry_cookie_days }}</label>
              <div class="col-sm-9"><input type="number" min="1" max="730" name="analytics_yandex_metrica_cookie_days" value="{{ analytics_yandex_metrica_cookie_days }}" id="input-cookie-days" class="form-control"><p class="help-block">{{ help_cookie_days }}</p>{% if error_cookie_days %}<div class="text-danger">{{ error_cookie_days }}</div>{% endif %}</div>
            </div>
            <div class="form-group">
              <label class="col-sm-3 control-label" for="input-privacy-information">{{ entry_privacy_information }}</label>
              <div class="col-sm-9"><select name="analytics_yandex_metrica_privacy_information_id" id="input-privacy-information" class="form-control"><option value="0">{{ text_none }}</option>{% for information in informations %}<option value="{{ information.information_id }}"{% if information.information_id == analytics_yandex_metrica_privacy_information_id %} selected{% endif %}>{{ information.title }}</option>{% endfor %}</select><p class="help-block">{{ help_privacy_information }}</p></div>
            </div>
            <ul class="nav nav-tabs" id="banner-language">{% for language in languages %}<li><a href="#banner-language-{{ language.language_id }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"> {{ language.name }}</a></li>{% endfor %}</ul>
            <div class="tab-content">
              {% for language in languages %}
              <div class="tab-pane" id="banner-language-{{ language.language_id }}">
                {% for field, label in {'title': entry_banner_title, 'description': entry_banner_description, 'privacy': entry_banner_privacy, 'accept': entry_banner_accept, 'reject': entry_banner_reject, 'settings': entry_banner_settings} %}
                <div class="form-group required">
                  <label class="col-sm-3 control-label" for="input-banner-{{ field }}-{{ language.language_id }}">{{ label }}</label>
                  <div class="col-sm-9">
                    {% if field == 'description' %}<textarea name="analytics_yandex_metrica_banner[{{ language.language_id }}][{{ field }}]" id="input-banner-{{ field }}-{{ language.language_id }}" rows="3" class="form-control">{{ analytics_yandex_metrica_banner[language.language_id][field] }}</textarea>{% else %}<input name="analytics_yandex_metrica_banner[{{ language.language_id }}][{{ field }}]" value="{{ analytics_yandex_metrica_banner[language.language_id][field] }}" id="input-banner-{{ field }}-{{ language.language_id }}" class="form-control">{% endif %}
                    {% if error_banner[language.language_id][field] %}<div class="text-danger">{{ error_banner[language.language_id][field] }}</div>{% endif %}
                  </div>
                </div>
                {% endfor %}
              </div>
              {% endfor %}
            </div>
          </fieldset>
        </form>
      </div>
    </div>
  </div>
</div>
<script>$('#banner-language a:first').tab('show');</script>
{{ footer }}
